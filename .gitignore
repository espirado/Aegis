# ─────────────────────────────────────────────────────────
# Data — NEVER commit datasets
# ─────────────────────────────────────────────────────────
data/raw/
data/processed/
data/splits/

# ─────────────────────────────────────────────────────────
# Models — download or build via scripts
# ─────────────────────────────────────────────────────────
ml/models/*.onnx
ml/models/*.pt
ml/models/*.bin

# ─────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# ─────────────────────────────────────────────────────────
# Go
# ─────────────────────────────────────────────────────────
bin/
*.exe
vendor/

# ─────────────────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ─────────────────────────────────────────────────────────
# Environment / Secrets
# ─────────────────────────────────────────────────────────
.env
.env.*
*.key
*.pem

# ─────────────────────────────────────────────────────────
# Evaluation results (regenerated, large)
# ─────────────────────────────────────────────────────────
ml/eval/results/

# ─────────────────────────────────────────────────────────
